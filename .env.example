# Copy this to .env and fill in your values
BOT_TOKEN=your_telegram_bot_token_here

# Optional: restrict bot to your chat only (get it from @userinfobot)
OWNER_CHAT_ID=your_telegram_chat_id

# Postgres connection string, shared by the bot and the web app
# e.g. postgres://user:password@host:5432/miguquest
DATABASE_URL=postgres://user:password@localhost:5432/miguquest

# Public URL of the web app (used to build /web login links and /share links)
WEB_BASE_URL=https://miguquest-web.example.com

# Secret used to sign web session cookies — set to a long random string
SESSION_SECRET=change_me_to_a_long_random_string
